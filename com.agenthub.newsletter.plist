<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agenthub.newsletter</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/bricks/Developer/mail-workflow/scripts/run-agent.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/bricks/Developer/mail-workflow/data/launchd-out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/bricks/Developer/mail-workflow/data/launchd-err.log</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
