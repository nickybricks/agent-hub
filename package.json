{
  "name": "mail-workflow",
  "version": "0.31.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "agent:run": "npx tsx --env-file=.env.local src/agent/run.ts",
    "schedule:install": "bash scripts/install-schedule.sh",
    "schedule:uninstall": "bash scripts/uninstall-schedule.sh",
    "mail:analyze": "npx tsx --env-file=.env.local src/agent/analyze-mailbox.ts",
    "mail:classify": "npx tsx --env-file=.env.local src/agent/classify-senders.ts",
    "mail:audit": "npx tsx --env-file=.env.local src/agent/audit.ts",
    "mail:triage": "npx tsx --env-file=.env.local src/agent/triage.ts",
    "mail:spam-rescan": "npx tsx --env-file=.env.local src/agent/spam-rescan.ts",
    "mail:propose-structure": "npx tsx --env-file=.env.local src/agent/propose-structure.ts",
    "test": "node --test --import tsx 'src/**/__tests__/*.test.ts'",
    "test:db": "RUN_DB_TESTS=1 node --test --import tsx --env-file=.env.local 'src/**/__tests__/*.dbtest.ts'",
    "eval:injection": "npx tsx --env-file=.env.local scripts/eval-injection.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.40",
