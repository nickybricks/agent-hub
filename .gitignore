# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# mail analyzer DB (local cache, not source of truth)
data/mail-analyzer.db
data/mail-analyzer.db-shm
data/mail-analyzer.db-wal

# user data — may contain API keys and personal content
data/config.json
data/runs.json
data/summaries/
data/debug/
logs/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
